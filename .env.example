# AWTRIX 3 Client — configuration

# Required: IP address or hostname of your AWTRIX 3 device
AWTRIX_HOST=192.168.1.100

# Optional: MQTT broker URL (if you want MQTT transport in addition to HTTP)
# AWTRIX_MQTT_BROKER=tcp://192.168.1.10:1883

# Optional: MQTT topic prefix configured on your AWTRIX device (default: awtrix)
# AWTRIX_MQTT_PREFIX=awtrix
