{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node \"${PLUGIN_ROOT}/hooks/awtrix-activate.js\"",
        "powershell": "node \"${PLUGIN_ROOT}\\hooks\\awtrix-activate.js\"",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node \"${PLUGIN_ROOT}/hooks/awtrix-mode-tracker.js\"",
        "powershell": "node \"${PLUGIN_ROOT}\\hooks\\awtrix-mode-tracker.js\"",
        "timeoutSec": 5
      }
    ]
  }
}
